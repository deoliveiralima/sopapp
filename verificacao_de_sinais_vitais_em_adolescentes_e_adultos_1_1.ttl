base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_1 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 1 ;
    sop:name "Higienização Simples das Mãos"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_10 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 10 ;
    sop:name "Higienização Simples das Mãos"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_11 a sop:Step ;
    sop:discriminator 11 ;
    sop:name "Anotar o procedimento realizado no prontuário do cliente, registrando a frequência em bpm e descrevendo as características do pulso encontrado."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_12 a sop:Step ;
    sop:discriminator 12 ;
    sop:name "Repetir o procedimento conforme prescrição médica e de enfermagem"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_2 a sop:Step ;
    sop:discriminator 2 ;
    sop:name "Orientar o cliente quanto ao procedimento"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_3 a sop:Step ;
    sop:discriminator 3 ;
    sop:name "Preparar o material necessário"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_4 a sop:Step ;
    sop:discriminator 4 ;
    sop:name "Posicionar o cliente em posição confortável: se o cliente estiver em posição supina, colocar o antebraço ao lado da região inferior do tórax com o punho estendido e a palma da mão para baixo; se estiver sentado, dobrar seu cotovelo a 90°, apoiar seu antebraço, estender suavemente o punho com a palma da mão votada para baixo."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_5 a sop:Step ;
    sop:discriminator 5 ;
    sop:name " Aquecer as mãos, se necessário, friccionando-as"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_6 a sop:Step ;
    sop:discriminator 6 ;
    sop:name "Palpar a artéria escolhida (artéria radial, por exemplo)"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_7 a sop:Step ;
    sop:discriminator 7 ;
    sop:name "Colocar as polpas digitais dos dedos, médio e indicador, sobre uma artéria superficial comprimindo-a suavemente."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_8 a sop:Step ;
    sop:discriminator 8 ;
    sop:name "Contar os batimentos arteriais durante 1 minuto."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_1_9 a sop:Step ;
    sop:discriminator 9 ;
    sop:name "Verificar a frequência, ritmo e intensidade do pulso. Repita o procedimento, se necessário."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_1 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 1 ;
    sop:name "Higienização Simples das Mãos"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_10 a sop:Step ;
    sop:discriminator 10 ;
    sop:name "Quando auscultar os sons cardíacos olhar para o relógio e começar a contar a frequência; começar a contar do zero e em seguida um, dois e assim por diante. Conte por 1 minuto."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_11 a sop:Step ;
    sop:discriminator 11 ;
    sop:name "Note se a frequência cardíaca está regular ou irregular."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_12 a sop:Step ;
    sop:discriminator 12 ;
    sop:name "Realizar novamente a assepsia das olivas do diafragma do estetoscópio com algodão embebido com álcool a 70%."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_13 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 13 ;
    sop:name "Higienização Simples das Mãos"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_14 a sop:Step ;
    sop:discriminator 14 ;
    sop:name "Repetir o procedimento conforme prescrição médica e de enfermagem"^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_2 a sop:Step ;
    sop:discriminator 2 ;
    sop:name "Orientar o cliente quanto ao procedimento."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_3 a sop:Step ;
    sop:discriminator 3 ;
    sop:name "Posicionar o cliente em posição confortável, preferencialmente posição supina ou sentada."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_4 a sop:Step ;
    sop:discriminator 4 ;
    sop:name "Manter a privacidade do cliente."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_5 a sop:Step ;
    sop:discriminator 5 ;
    sop:name "Afastar a roupa do cliente para descobrir o esterno e o lado esquerdo do peito."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_6 a sop:Step ;
    sop:discriminator 6 ;
    sop:name "Realizar a assepsia das olivas e do diafragma do estetoscópio com algodão embebido em álcool 70%."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_7 a sop:Step ;
    sop:discriminator 7 ;
    sop:name "Localizar os pontos de referência anatômicos para identificar o pulso apical."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_8 a sop:Step ;
    sop:discriminator 8 ;
    sop:name "Colocar o diafragma do estetoscópio na palma da mão por 5 a 10 segundos."^^xsd:string .

base:step_verificacao_de_sinais_vitais_em_adolescentes_e_adultos_1_1_2_9 a sop:Step ;
    sop:discriminator 9 ;
    sop:name "Colocar o diafragma do estetoscópio sobre o pulso apical (quinto espaço intercostal esquerdo na linha hemiclavicular), e auscultar em busca dos sons cardíacos (ouvidos como Tum Ta)."^^xsd:string .

