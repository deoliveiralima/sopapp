    sop:creationDate "2020-10-30T00:00:00"^^xsd:dateTime ;
    sop:description """É a medida individual mais simples, rápida, econômica, eficaz e
importante para prevenir a propagação das Infecções Relacionadas à Assistência à
Saúde (IRAS), visando à segurança do cliente e dos profissionais de saúde."""^^xsd:string ;
    sop:includes base:step_higienização_simples_das_mãos_1_1_1,
        base:step_higienização_simples_das_mãos_1_1_2,
        base:step_higienização_simples_das_mãos_1_1_3 ;
    sop:name "HIGIENIZAÇÃO SIMPLES DAS MÃOS"^^xsd:string ;
