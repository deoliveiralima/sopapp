        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_8 ;
    sop:name "Sequência de Paramentação"^^xsd:string .

base:section_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2 a sop:Section ;
    sop:discriminator 2 ;
    sop:hasStep base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_1,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_10,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_11,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_12,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_2,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_3,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_4,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_5,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_6,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_7,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_8,
        base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_9 ;
    sop:name "Sequência de Desparamentação"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_1 a sop:Step ;
    sop:discriminator 1 ;
    sop:name "Reunir o material necessário"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_2 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 2 ;
    sop:name "Higienização simples das mãos"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_3 a sop:Step ;
    sop:discriminator 3 ;
    sop:name "Vestir o avental primeiramente pelas mangas, ajustando as amarras nas costas e cintura. Certifique-se de que o tronco esteja totalmente coberto, bem como os braços e os punhos. Lembre-se: Nunca amarre o avental pela frente."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_4 a sop:Step ;
    sop:discriminator 4 ;
    sop:name "Colocar a máscara (cirúrgica ou N95 conforme atividade ou procedimento a ser realizado)."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_5 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 5 ;
    sop:name "Higienização simples das mãos"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_6 a sop:Step ;
    sop:discriminator 6 ;
    sop:name "Se óculos de proteção → Colocar óculos de proteção → 7. Colocar gorro/touca Se protetor facial → Colocar gorro/touca → 7. Colocar protetor facial"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_7 a sop:Step ;
    sop:discriminator 7 ;
    sop:name "Higienizar as mãos."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_1_8 a sop:Step ;
    sop:discriminator 8 ;
    sop:name " Calçar as luvas conforme procedimento a ser realizado e ajustá-las até cobrir o punho do avental."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_1 a sop:Step ;
    sop:discriminator 1 ;
    sop:name "Retirar as luvas de procedimento ou estéreis; (Retire a primeira luva puxando-a pelo lado externo do punho com os dedos da mão oposta → Segure a luva removida com a outra mão enluvada → Toque a parte interna do punho da mão enluvada com o dedo indicador oposto (sem luvas) e retire a outra luva, deixando a primeira luva dentro da segunda → Descarte as luvas na lixeira de resíduo infectante)."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_10 a sop:Step ;
    sop:discriminator 10 ;
    sop:name "Retirar as luvas e descartar em lixo infectante."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_11 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 11 ;
    sop:name "Higienização simples das mãos"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_12 a sop:Step ;
    sop:discriminator 12 ;
    sop:name "Retirar a máscara pelas tiras/elástico evitando tocar na parte da frente e higienizar as mãos novamente."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_2 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 2 ;
    sop:name "Higienização simples das mãos"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_3 a sop:Step ;
    sop:discriminator 3 ;
    sop:name "Retirar o avental descartável com cuidado para não contaminar a roupa; (Abra as tiras e solte as amarras → Empurre pelo pescoço e pelos ombros de forma segura sem movimentos bruscos para não levantar gotículas, toque apenas na parte interna do avental → Retire o avental pelo avesso → Despreze no lixo infectante)."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_4 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 4 ;
    sop:name "Higienização simples das mãos"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_5 a sop:Step ;
    sop:discriminator 5 ;
    sop:name "Remover o gorro/touca puxando pela parte posterior da cabeça e descartar em lixo infectante. Obs.: Se estiver utilizando protetor facial removê-lo antes do gorro."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_6 a sop:Step ;
    rdfs:seeAlso base:higienizacao_simples_das_maos_1_1 ;
    sop:discriminator 6 ;
    sop:name "Higienização simples das mãos"^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_7 a sop:Step ;
    sop:discriminator 7 ;
    sop:name "Calçar luvas de procedimento."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_8 a sop:Step ;
    sop:discriminator 8 ;
    sop:name "Remover os óculos de proteção tocando delicadamente na extremidade lateral, próximo a região auricular."^^xsd:string .

base:step_paramentacao_e_desparamentacao_de_equipamentos_de_protecao_individual_epis_1_1_2_9 a sop:Step ;
    sop:discriminator 9 ;
    sop:name "Realizar a limpeza e desinfecção dos óculos e/ou protetor facial conforme descrito: I. Utilizar água e sabão/detergente; II. Secar manualmente com material absorvente limpo e macio; III. Desinfetar por três vezes com álcool a 70% → borrifar e realizar a fricção por 30 segundos iniciando pela parte interna e depois externa, atentando-se para realizar o movimento em sentido unidirecional, do menos contaminado para o mais contaminado; IV. Embalar ou armazenar em recipiente limpo destinado para sua guarda."^^xsd:string .

base:term_d0f92a90 a skos:Concept ;
    skos:definition "Equipamentos de Proteção Individual"^^xsd:string ;
    skos:prefLabel "EPI"^^xsd:string .

