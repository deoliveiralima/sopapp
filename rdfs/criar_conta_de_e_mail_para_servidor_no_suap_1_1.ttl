    sop:name "Etapas"^^xsd:string .

base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_1 a sop:Step ;
    sop:discriminator 1 ;
    sop:name "Acessar SUAP https://suap.iff.edu.br/"^^xsd:string .

base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_2 a sop:Step ;
    sop:discriminator 2 ;
    sop:name "Na barra lateral esquerda abrir a arvore de submenus abaixo de Tec. da Informçaõ"^^xsd:string .

base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_3 a sop:Step ;
    sop:discriminator 3 ;
    sop:name "Clicar em e-mail e em Criar e-mail Servidor/Estagiário"^^xsd:string .

base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_4 a sop:Step ;
    sop:discriminator 4 ;
    sop:name "Na nova tela, buscar pelo nome do servidor"^^xsd:string .

base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_5 a sop:Step ;
    sop:discriminator 5 ;
    sop:name "Na tela seguinte, seleciona o nome de usuário informar a senha e confirmá-la"^^xsd:string .

base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_6 a sop:Step ;
    sop:discriminator 6 ;
    sop:name "Por fim, clicar em enviar"^^xsd:string .

