base:item_21c18dc7 a sop:Note ;
    sop:discriminator 1 ;
    sop:name "Para o cadastro do usuário ser efetuado, é necessário o preenchimento do “Formulário de Solicitação de Conta de E-mail Institucional.odt ”, assinado pelo Coordenador do Setor onde o usuário esteja alocado." .

base:item_bf1c9508 a sop:Objective ;
    sop:discriminator 1 ;
    sop:name "Este documento tem como objetivo apresentar de maneira simplificada a forma de acesso ao Sistema de Criação de email e a maneira de criar uma conta, através do preenchimento dos campos necessários." .

base:section_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1 a sop:Section ;
    sop:discriminator 1 ;
    sop:hasStep base:step_criar_conta_de_e_mail_para_servidor_no_suap_1_1_1_1,
