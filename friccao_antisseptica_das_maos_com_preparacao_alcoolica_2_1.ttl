base:friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1 a sop:Sop ;
    sop:approvedBy base:agent_5bcfba03 ;
    sop:checkedBy base:agent_5bcfba03 ;
    sop:classification base:concept_909681fd ;
    sop:createdBy base:anaSilva ;
    sop:description "Consiste na higiene das mãos utilizando uma preparação antisséptica a base de álcool sob as formas líquida, gel, espuma ou outras, que tem como finalidade reduzir ou inibir o crescimento de microrganismos nas mãos."^^xsd:string ;
    sop:includes base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_1,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_2,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_3,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_4,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_5,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_6,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_7,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_8,
        base:step_friccao_antisseptica_das_maos_com_preparacao_alcoolica_2_1_9 ;
    sop:name "FRICÇÃO ANTISSÉPTICA DAS MÃOS COM PREPARAÇÃO ALCOÓLICA"^^xsd:string ;
    sop:performedAt base:IFF ;
    sop:performedBy base:SetorEnfermagem ;
    sop:responsible base:IFF ;
    sop:sopItem base:item_15f61abf,
        base:item_315f867a,
        base:item_44075893,
        base:item_6c648c88,
        base:item_7a45c1bd,
        base:item_8d0ad2e1,
        base:item_8e93bfdd,
        base:item_956ea217,
        base:item_9868719b,
        base:item_9e703101,
        base:item_a8488ce9,
        base:item_ce7f3314,
        base:item_d1f9f307,
        base:item_d25041ed,
        base:item_db3f2c38,
        base:item_dc628286,
        base:item_dd4f94d9,
